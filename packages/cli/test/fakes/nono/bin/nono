#!/usr/bin/env bash
# =============================================================================
# FAKE nono binary — for use in TPS test environments ONLY
#
# Simulates the nono CLI interface without kernel enforcement.
# Real nono: https://nono.sh
#
# Usage:
#   nono run --profile <name> [--workdir <path>] -- <command> [args...]
#   nono --version
#   nono --help
#
# Environment variables (for test control):
#   NONO_FAKE_LOG     Path to log file (default: /tmp/nono-fake.log)
#   NONO_FAKE_STRICT  If set, exit non-zero when profile not found (default: behavior)
#   NONO_FAKE_CANARY  If set, checks if this path is accessible. Used for S4.1 verification.
#                     The fake logs whether it could read the canary file.
#
# The fake logs every invocation to NONO_FAKE_LOG so tests can inspect calls.
# =============================================================================

set -eo pipefail

FAKE_VERSION="0.0.1-fake"
LOG_FILE="${NONO_FAKE_LOG:-/tmp/nono-fake.log}"
PROFILE_DIRS=(
  "${HOME:-}/.config/nono/profiles"
  "$(dirname "$0")/../profiles"
)

# Resolve this script's "profiles" dir relative to binary location
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUILTIN_PROFILE_DIR="${SCRIPT_DIR}/../profiles"
# Resolve if it exists, else keep relative (cd would fail with set -e)
if [[ -d "${BUILTIN_PROFILE_DIR}" ]]; then
  BUILTIN_PROFILE_DIR="$(cd "${BUILTIN_PROFILE_DIR}" && pwd)"
fi

log() {
  echo "[nono-fake $(date -u +%Y-%m-%dT%H:%M:%SZ)] $*" >> "$LOG_FILE"
}

die() {
  echo "nono: error: $*" >&2
  log "ERROR: $*"
  exit 1
}

# -----------------------------------------------------------------------
# Subcommand: --version
# -----------------------------------------------------------------------
if [[ "${1:-}" == "--version" ]] || [[ "${1:-}" == "-V" ]]; then
  echo "nono $FAKE_VERSION (fake — kernel enforcement disabled)"
  exit 0
fi

# -----------------------------------------------------------------------
# Subcommand: --help
# -----------------------------------------------------------------------
if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]] || [[ -z "${1:-}" ]]; then
  cat <<EOF
nono $FAKE_VERSION (fake — kernel enforcement disabled)

USAGE:
  nono run [OPTIONS] -- <command> [args...]

OPTIONS:
  --profile <name>    Apply named profile from ~/.config/nono/profiles/<name>.toml
  --workdir <path>    Override working directory for sandbox
  --allow <path>      Grant read+write access to path (adds to profile)
  --read <path>       Grant read-only access to path (adds to profile)
  --allow-cwd         Skip CWD sharing prompt
  -V, --version       Print version
  -h, --help          Print help

ENVIRONMENT (fake-specific):
  NONO_FAKE_LOG       Log file path (default: /tmp/nono-fake.log)
  NONO_FAKE_CANARY    Canary file path for enforcement verification (S4.1)

NOTE: This is a test fake. No kernel enforcement is applied.
      Install real nono from https://nono.sh for production use.
EOF
  exit 0
fi

# -----------------------------------------------------------------------
# Subcommand: run
# -----------------------------------------------------------------------
if [[ "${1:-}" != "run" ]]; then
  die "unknown subcommand: '${1:-}'. Expected 'run'"
fi
shift

# --- Parse arguments ---
PROFILE_NAME=""
WORKDIR_OVERRIDE=""
EXTRA_ALLOW=()
EXTRA_READ=()
SKIP_CWD_PROMPT=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)
      PROFILE_NAME="${2:?--profile requires a value}"
      shift 2
      ;;
    --workdir)
      WORKDIR_OVERRIDE="${2:?--workdir requires a value}"
      shift 2
      ;;
    --allow)
      EXTRA_ALLOW+=("${2:?--allow requires a path}")
      shift 2
      ;;
    --read)
      EXTRA_READ+=("${2:?--read requires a path}")
      shift 2
      ;;
    --allow-cwd)
      SKIP_CWD_PROMPT=true
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      die "unknown flag: '$1'"
      ;;
  esac
done

if [[ $# -eq 0 ]]; then
  die "no command specified after --"
fi

COMMAND=("$@")

# --- Resolve profile ---
PROFILE_FILE=""
PROFILE_TOML_CONTENT=""

if [[ -n "$PROFILE_NAME" ]]; then
  # Search profile dirs in order: user dir, then builtin dir
  for dir in "${HOME:-}/.config/nono/profiles" "$BUILTIN_PROFILE_DIR"; do
    candidate="$dir/${PROFILE_NAME}.toml"
    if [[ -f "$candidate" ]]; then
      PROFILE_FILE="$candidate"
      PROFILE_TOML_CONTENT=$(cat "$candidate")
      break
    fi
  done

  if [[ -z "$PROFILE_FILE" ]]; then
    log "PROFILE_NOT_FOUND profile=$PROFILE_NAME"
    die "profile not found: '$PROFILE_NAME'. Searched: ${HOME:-}/.config/nono/profiles/, $BUILTIN_PROFILE_DIR"
  fi

  log "PROFILE_LOADED profile=$PROFILE_NAME file=$PROFILE_FILE"
else
  log "NO_PROFILE command=${COMMAND[*]}"
fi

# --- Canary check (for S4.1 — enforcement verification) ---
if [[ -n "${NONO_FAKE_CANARY:-}" ]]; then
  if [[ -r "$NONO_FAKE_CANARY" ]]; then
    log "CANARY_ACCESSIBLE path=$NONO_FAKE_CANARY (WARN: real nono would block this)"
    # In fake mode, we warn but don't block — real enforcement test needs real nono in Docker
    echo "nono-fake: WARNING: canary file is accessible (no kernel enforcement in fake mode)" >&2
  else
    log "CANARY_INACCESSIBLE path=$NONO_FAKE_CANARY"
  fi
fi

# --- Log invocation ---
log "INVOKE profile=${PROFILE_NAME:-none} workdir=${WORKDIR_OVERRIDE:-cwd} command=${COMMAND[*]}"

# --- Execute command ---
if [[ -n "$WORKDIR_OVERRIDE" ]]; then
  cd "$WORKDIR_OVERRIDE"
fi

exec "${COMMAND[@]}"

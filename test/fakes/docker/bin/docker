#!/bin/sh
set -e
cmd="$1"
sub="$2"

# Debug logging for CI diagnosis
echo "FAKE_DOCKER: cmd=$cmd sub=$sub args=$@" >&2

if [ "$cmd" != "sandbox" ]; then
  echo "unsupported" >&2
  exit 1
fi

if [ "$sub" = "create" ]; then
  echo "created"
  exit 0
fi

if [ "$sub" = "run" ]; then
  echo "sandbox-test-id"
  exit 0
fi

if [ "$sub" = "exec" ]; then
  exit 0
fi

if [ "$sub" = "stop" ]; then
  if [ -n "$FAIL_STOP" ]; then
    echo "not found" >&2
    exit 1
  fi
  exit 0
fi

if [ "$sub" = "list" ] || [ "$sub" = "ls" ]; then
  if [ -n "$LIST_LINE" ]; then
    echo "$LIST_LINE"
  fi
  # If json requested, return empty vms list to simulate "not found" cleanly
  # POSIX sh check for --json in arguments
  args="$*"
  case "$args" in
    *"--json"*)
      echo '{ "vms": [] }'
      ;;
  esac
  exit 0
fi

echo "unknown command: $cmd $sub" >&2
exit 1
